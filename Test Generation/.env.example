# LLM API Keys (used by LiteLLM)
# Add your keys here to avoid passing --api-key on the command line every time.

OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY="..."

# Optional: Configuration for local models (e.g., Ollama, vLLM)
# OPENAI_API_BASE="http://localhost:11434/v1"

# Enable Debug Logging
DEBUG=True

# Default Model for zero/few-shot baseline scripts
MODEL="openai/gpt-4o"
