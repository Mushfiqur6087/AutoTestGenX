      "type": "data_table",
      "columns": [
        "Teller Name",
        "Office",
        "Status",
        "Description"
      ],
      "row_actions": [
        {
          "action_name": "Open Teller Detail",
          "navigates_to": "Teller_Detail_Page",
          "trigger_hint": "click Teller Name"
        }
      ],
      "bulk_actions": []
    },
    "Create_Teller_Action": {
      "type": "button",
      "on_click": "opens Create_Teller_Form"
    },
    "Create_Teller_Form": {
      "type": "form",
      "fields": {
        "Office": {
          "type": "unspecified",
          "required": true
        },
        "Teller_Name": {
          "type": "unspecified",
          "required": true
        },
        "Description": {
          "type": "unspecified",
          "required": false
        },
        "Start_Date": {
          "type": "date",
          "required": true
        },
        "End_Date": {
          "type": "date",
          "required": false
        },
        "Status": {
          "type": "dropdown",
          "required": false,
          "options": [
            "Active",
            "Inactive"
          ]
        }
      },
      "submit_actions": [
        {
          "on_success": "creates teller"
        }
      ]
    },
    "Teller_Detail_Page": {
      "type": "page",
      "components": {
        "Edit_Teller_Action": {
          "type": "button",
          "on_click": "opens Edit_Teller_Form"
        },
        "Edit_Teller_Form": {
          "type": "form",
          "fields": {},
          "submit_actions": []
        },
        "Cashiers_Table": {
          "type": "data_table",
          "columns": [
            "Cashier Name",
            "Start Date",
            "End Date",
            "Is Full Day",
            "Status"
          ],
          "row_actions": [],
          "bulk_actions": []
        },
        "Allocate_Cashier_Action": {
          "type": "button",
          "on_click": "opens Allocate_Cashier_Form"
        }
      }
    },
    "Allocate_Cashier_Form": {
      "type": "form",
      "fields": {
        "Staff": {
          "type": "unspecified",
          "required": true
        },
        "Start_Date": {
          "type": "date",
          "required": true
        },
        "End_Date": {
          "type": "date",
          "required": false
        },
        "Is_Full_Day": {
          "type": "checkbox",
          "required": false
        },
        "Description": {
          "type": "unspecified",
          "required": false
        }
      },
      "submit_actions": [
        {
          "on_success": "allocates cashier to teller"
        }
      ]
    },
    "Cashier_Detail_Page": {
      "type": "page",
      "components": {
        "Allocate_Cash_Action": {
          "type": "action",
          "action_name": "Allocate Cash",
          "fields": {},
          "on_success": "adds cash from vault to cashier"
        },
        "Settle_Cash_Action": {
          "type": "action",
          "action_name": "Settle Cash",
          "fields": {
            "Amount": {
              "type": "number",
              "required": true
            },
            "Currency": {
              "type": "unspecified",
              "required": true
            },
            "Transaction_Date": {
              "type": "date",
              "required": true
            }
          },
          "on_success": "returns cash from cashier to vault"
        },
        "Cashier_Transactions_Table": {
          "type": "data_table",
          "columns": [
            "Date",
            "Type",
            "Amount",
            "Running Balance"
          ],
          "row_actions": [],
          "bulk_actions": []
        }
      }
    }
  }
}
