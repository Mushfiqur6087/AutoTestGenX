      "steps": ["1. Step one", "2. Step two"],
      "expected_result": "What error/block should occur, naming the field and indicator",
      "priority": "high | medium"
    }
  ],
  "summary": {
    "total": 0,
    "high_priority": 0,
    "medium_priority": 0,
    "low_priority": 0
  }
}


