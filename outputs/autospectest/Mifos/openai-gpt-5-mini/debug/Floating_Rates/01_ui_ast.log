          "item_fields": {
            "From_Date": {
              "type": "date",
              "required": false
            },
            "Interest_Rate": {
              "type": "number",
              "required": false,
              "constraints": [
                "percentage"
              ]
            },
            "Is_Differential_Rate": {
              "type": "checkbox",
              "required": false,
              "constraints": [
                "if checked, rate is applied relative to the base lending rate (added to or subtracted from base) rather than used as an absolute rate"
              ]
            }
          },
          "add_row_action": {
            "element_name": "Add Rate Period",
            "action": "adds a new Rate_Period row"
          }
        }
      },
      "submit_actions": [
        {
          "on_success": "updates floating rate; linked loan products' interest rates adjust automatically based on applicable rate period"
        }
      ]
    }
  }
}
