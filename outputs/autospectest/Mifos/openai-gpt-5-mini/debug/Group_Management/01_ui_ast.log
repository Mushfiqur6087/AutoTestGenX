        },
        "External_Id": {
          "type": "unspecified",
          "required": false
        },
        "Add_Clients": {
          "type": "search",
          "required": false,
          "description": "search existing clients to associate with the group",
          "adds_to": "Selected_Clients"
        },
        "Selected_Clients": {
          "type": "repeating_group",
          "min": 0,
          "item_fields": {
            "Client_Id": {
              "type": "unspecified"
            },
            "Client_Name": {
              "type": "link"
            }
          }
        }
      },
      "submit_actions": [
        {
          "element_name": "Submit",
          "on_success": "creates group"
        }
      ]
    },
    "Bulk_Import_Groups_Page": {
      "type": "page",
      "components": {
        "Groups_Template_Panel": {
          "type": "form",
          "fields": {
            "Office": {
              "type": "dropdown",
              "required": false
            },
            "Staff": {
              "type": "dropdown",
              "required": false
            }
          },
          "actions": [
            {
              "action_name": "Download Template",
              "on_click": "downloads groups template"
            }
          ]
        },
        "Groups_Upload_Panel": {
          "type": "form",
          "fields": {
            "File": {
              "type": "file_upload",
              "required": true
            }
          },
          "actions": [
            {
              "action_name": "Upload",
              "on_success": "imports groups and records import history"
            }
          ]
        },
        "Import_History_Table": {
          "type": "data_table",
          "columns": [],
          "row_actions": []
        }
      }
    },
    "Group_Detail_Page": {
      "type": "page",
      "components": {
        "Group_Action_Bar": {
          "type": "state_bound_action_bar",
          "states": {
            "Pending": {
              "available_actions": [
                {
                  "action_name": "Activate",
                  "on_success": "changes status to Active",
                  "preconditions": [
                    "status must be Pending"
                  ]
                },
                {
                  "action_name": "Edit"
                },
                {
                  "action_name": "Close",
                  "on_success": "changes status to Closed",
                  "preconditions": [
                    "status must be Pending or Active"
                  ]
                },
                {
                  "action_name": "Assign Staff",
                  "fields": {
                    "Staff": {
                      "type": "dropdown",
                      "required": true
                    }
                  }
                },
                {
                  "action_name": "Transfer Clients"
                }
              ]
            },
            "Active": {
              "available_actions": [
                {
                  "action_name": "Edit"
                },
                {
                  "action_name": "Close",
                  "on_success": "changes status to Closed",
                  "preconditions": [
                    "status must be Active"
                  ]
                },
                {
                  "action_name": "Assign Staff",
                  "fields": {
                    "Staff": {
                      "type": "dropdown",
                      "required": true
                    }
                  }
                },
                {
                  "action_name": "Transfer Clients"
                }
              ]
            },
            "Closed": {
              "available_actions": [
                {
                  "action_name": "Activate",
                  "on_success": "changes status to Active",
                  "preconditions": [
                    "status must be Closed"
                  ]
                },
                {
                  "action_name": "Edit"
                },
                {
                  "action_name": "Assign Staff",
                  "fields": {
                    "Staff": {
                      "type": "dropdown",
                      "required": true
                    }
                  }
                },
                {
                  "action_name": "Transfer Clients"
                }
              ]
            }
          }
        },
        "Group_Detail_Tabs": {
          "type": "tab_container",
          "tabs": [
            {
              "tab_name": "Members",
              "fields": {
                "Members_List": {
                  "type": "data_table",
                  "columns": [
                    "Client Name"
                  ],
                  "row_fields": {
                    "Client_Name": {
                      "type": "link"
                    }
                  },
                  "row_actions": [
                    {
                      "action_name": "Open Client Profile",
                      "trigger": "Client Name link",
                      "on_success": "navigates to client profile"
                    }
                  ]
                }
              }
            },
            {
              "tab_name": "Loan Accounts",
              "fields": {
                "Loan_Accounts_Table": {
                  "type": "data_table",
                  "columns": [],
                  "row_actions": []
                }
              }
            },
            {
              "tab_name": "Savings Accounts",
              "fields": {
                "Savings_Accounts_Table": {
                  "type": "data_table",
                  "columns": [],
                  "row_actions": []
                }
              }
            },
            {
              "tab_name": "Notes",
              "fields": {}
            },
            {
              "tab_name": "Calendar/Meeting",
              "fields": {},
              "actions": [
                {
                  "action_name": "Schedule Meeting",
                  "on_success": "schedules group meeting"
                },
                {
                  "action_name": "Record Meeting",
                  "on_success": "records meeting details"
                }
              ]
            }
          ]
        }
      }
    },
    "Collection_Sheet": {
      "type": "feature",
      "description": "Generates a sheet showing all group clients with loan repayment and savings deposit amounts for batch entry",
      "actions": [
        {
          "action_name": "Generate Collection Sheet",
          "on_success": "opens collection sheet for batch entry"
        }
      ],
      "collection_sheet_table": {
        "type": "data_table",
        "row_fields": {
          "Client_Name": {
            "type": "readonly_text"
          },
          "Loan_Repayment_Amount": {
            "type": "number",
            "editable": true
          },
          "Savings_Deposit_Amount": {
            "type": "number",
            "editable": true
          }
        },
        "row_actions": []
      }
    }
  }
}
