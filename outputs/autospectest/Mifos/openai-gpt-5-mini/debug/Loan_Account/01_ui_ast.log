              "on_change": "auto-populate default values from selected product"
            },
            "Loan_Officer": {
              "type": "unspecified",
              "required": false
            },
            "Loan_Purpose": {
              "type": "unspecified",
              "required": false
            },
            "Fund": {
              "type": "unspecified",
              "required": false
            },
            "Submitted_On": {
              "type": "date",
              "required": false
            },
            "Expected_Disbursement_Date": {
              "type": "date",
              "required": false
            },
            "Principal": {
              "type": "number",
              "required": true,
              "constraints": [
                "min: product.min_principal",
                "max: product.max_principal"
              ]
            },
            "Number_of_Repayments": {
              "type": "number",
              "required": true
            },
            "Repaid_Every": {
              "type": "number",
              "required": true
            },
            "Repaid_Every_Unit": {
              "type": "dropdown",
              "required": true
            },
            "Interest_Rate": {
              "type": "number",
              "required": true,
              "constraints": [
                "min: product.min_interest_rate",
                "max: product.max_interest_rate"
              ]
            },
            "External_ID": {
              "type": "unspecified",
              "required": false
            }
          }
        },
        {
          "step_index": 2,
          "step_name": "Terms",
          "fields": {
            "Repayment_Strategy": {
              "type": "dropdown",
              "required": false,
              "prefill_from_product": true
            },
            "Amortization": {
              "type": "dropdown",
              "required": false,
              "prefill_from_product": true
            },
            "Interest_Method": {
              "type": "dropdown",
              "required": false,
              "prefill_from_product": true
            },
            "Interest_Calculation_Period": {
              "type": "dropdown",
              "required": false,
              "prefill_from_product": true
            },
            "Grace_Period": {
              "type": "unspecified",
              "required": false
            }
          }
        },
        {
          "step_index": 3,
          "step_name": "Charges",
          "fields": {
            "Charges": {
              "type": "repeating_group",
              "item_fields": {}
            }
          },
          "actions": [
            {
              "element_name": "Add Charge",
              "type": "button",
              "triggers": "adds row to Charges"
            }
          ]
        },
        {
          "step_index": 4,
          "step_name": "Collateral",
          "fields": {
            "Collateral_Items": {
              "type": "repeating_group",
              "required": false,
              "item_fields": {
                "Collateral_Type": {
                  "type": "unspecified",
                  "required": true
                },
                "Value": {
                  "type": "number",
                  "required": true
                },
                "Description": {
                  "type": "unspecified",
                  "required": false
                }
              }
            }
          }
        }
      ]
    },
    "Loan_Detail_Page": {
      "type": "detail_page",
      "header_links": {
        "Client": {
          "type": "link",
          "target": "components.Client_Detail_Page"
        }
      }
    },
    "Loan_Detail_Actions": {
      "type": "state_bound_action_bar",
      "states": {
        "Submitted and Pending Approval": {
          "available_actions": [
            {
              "action_name": "Approve",
              "fields": {
                "Approved_On_Date": {
                  "type": "date",
                  "required": true
                },
                "Approved_Amount": {
                  "type": "number",
                  "required": true
                },
                "Expected_Disbursement_Date": {
                  "type": "date",
                  "required": false
                },
                "Note": {
                  "type": "unspecified",
                  "required": false
                }
              }
            },
            {
              "action_name": "Reject"
            },
            {
              "action_name": "Withdraw"
            },
            {
              "action_name": "Delete"
            }
          ]
        },
        "Approved": {
          "available_actions": [
            {
              "action_name": "Disburse",
              "fields": {
                "Disbursed_On_Date": {
                  "type": "date",
                  "required": true
                },
                "Transaction_Amount": {
                  "type": "number",
                  "required": true
                },
                "Payment_Type": {
                  "type": "dropdown",
                  "required": true,
                  "options": [
                    "Cash",
                    "Check",
                    "Mobile Money",
                    "Bank Transfer"
                  ]
                },
                "Payment_Details": {
                  "type": "unspecified",
                  "required": false
                },
                "Disburse_to_Savings": {
                  "type": "checkbox",
                  "required": false
                }
              }
            },
            {
              "action_name": "Undo Approval"
            }
          ]
        },
        "Active": {
          "available_actions": [
            {
              "action_name": "Make Repayment",
              "fields": {
                "Transaction_Date": {
                  "type": "date",
                  "required": true
                },
                "Transaction_Amount": {
                  "type": "number",
                  "required": true,
                  "prefill": "amount_due"
                },
                "Payment_Type": {
                  "type": "dropdown",
                  "required": true,
                  "options": [
                    "Cash",
                    "Check",
                    "Mobile Money",
                    "Bank Transfer"
                  ]
                },
                "Payment_Details": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "constraints": [
                "partial repayments are applied per the configured repayment strategy"
              ],
              "on_success": "if full settlement then status changes to Closed obligations met"
            },
            {
              "action_name": "Waive Interest"
            },
            {
              "action_name": "Write Off"
            },
            {
              "action_name": "Close"
            },
            {
              "action_name": "Reschedule",
              "fields": {
                "Reschedule_From_Date": {
                  "type": "date",
                  "required": true
                },
                "Reason": {
                  "type": "unspecified",
                  "required": true
                },
                "Adjusted_Due_Date": {
                  "type": "date",
                  "required": true
                },
                "Grace_Period": {
                  "type": "unspecified",
                  "required": false
                },
                "Extra_Terms": {
                  "type": "unspecified",
                  "required": false
                },
                "New_Interest_Rate": {
                  "type": "number",
                  "required": false
                }
              },
              "on_success": "creates a pending request requiring separate approval"
            },
            {
              "action_name": "Prepay Loan"
            },
            {
              "action_name": "Foreclosure"
            },
            {
              "action_name": "Charge Off"
            },
            {
              "action_name": "Assign Loan Officer",
              "fields": {
                "Loan_Officer": {
                  "type": "unspecified",
                  "required": true
                }
              }
            }
          ]
        },
        "Approved (no further actions)": {},
        "Closed": {},
        "Overpaid": {},
        "Written Off": {}
      }
    },
