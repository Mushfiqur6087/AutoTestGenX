  "test_cases": [
    {
      "tc_id": "E-001",
      "wf_ref": "WF-001",
      "subcategory": "boundary",
      "test_case": "Set price slider handles to identical value (zero-width range)",
      "preconditions": [
        "Listing page is open",
        "Listing_Type is set to a value where Price_Range is visible (any listing type)"
      ],
      "steps": [
        "1. Expand the Common Filters section if collapsed",
        "2. Locate the Price_Range slider",
        "3. Drag the left (minimum) slider handle to the same position as the right (maximum) slider handle (set both handles to identical value)",
        "4. Observe the Results_Grid and Result_Count",
        "5. Observe the Active_Filters_Summary"
      ],
      "expected_result": "Setting both slider handles to the same value succeeds; results update dynamically and Result_Count updates; Active_Filters_Summary shows a single Price range entry where the displayed min and max are identical (zero-width range shown)",
      "priority": "medium"
    },
    {
      "tc_id": "E-002",
      "wf_ref": "WF-001",
      "subcategory": "boundary",
      "test_case": "Attempt to move price slider left handle past right handle (handle-crossing)",
      "preconditions": [
        "Listing page is open",
        "Price_Range slider is visible"
      ],
      "steps": [
        "1. Expand the Common Filters section if collapsed",
        "2. Set Price_Range to an initial distinct min and max",
        "3. Attempt to drag the left (minimum) handle one step beyond the current right (maximum) handle position",
        "4. Observe whether the slider allows the handles to cross and observe Results_Grid and Result_Count"
      ],
      "expected_result": "Attempt to move the left handle past the right handle is blocked; slider handles do not cross and the Price_Range remains at its previous ordered values; Result_Count does not change as a result of the invalid drag and no new price range is applied",
      "priority": "medium"
    },
    {
      "tc_id": "E-003",
      "wf_ref": "WF-009",
      "subcategory": "boundary",
      "test_case": "Set Departure_Time_Range start time equal to end time",
      "preconditions": [
        "Listing page is open",
        "Listing_Type == Flights so Departure_Time_Range is visible"
      ],
      "steps": [
        "1. Expand the Flights Filters section if collapsed",
        "2. Open the Departure_Time_Range time_range control",
        "3. Set the start time to a specific time",
        "4. Set the end time to the exact same time as the start time",
        "5. Observe Results_Grid and Result_Count",
        "6. Observe Active_Filters_Summary"
      ],
      "expected_result": "Setting Departure_Time_Range start equal to end succeeds; results update dynamically and Result_Count updates; Active_Filters_Summary shows a departure time range filter entry with identical start and end times",
      "priority": "medium"
    },
    {
      "tc_id": "E-004",
      "wf_ref": "WF-009",
      "subcategory": "boundary",
      "test_case": "Set Departure_Time_Range start time one unit after end time (invalid ordering)",
      "preconditions": [
        "Listing page is open",
        "Listing_Type == Flights so Departure_Time_Range is visible"
      ],
      "steps": [
        "1. Expand the Flights Filters section if collapsed",
        "2. Open the Departure_Time_Range time_range control",
        "3. Set the end time to a specific time",
        "4. Set the start time to one unit after the end time (e.g., one minute after)",
        "5. Observe the time_range control for inline errors and observe Results_Grid and Result_Count"
      ],
      "expected_result": "Setting start time after end time is blocked / error shown; the UI shows an inline error indicating the start time cannot be after the end time (and does not apply the invalid range); Result_Count does not change due to the invalid input",
      "priority": "medium"
    },
    {
      "tc_id": "E-005",
      "wf_ref": "WF-006",
      "subcategory": "input_edge",
      "test_case": "Enter very long text into Hotels -> Location_Area (revealed by visible_when)",
      "preconditions": [
        "Listing page is open",
        "Listing_Type == Hotels so Location_Area filter is visible"
      ],
      "steps": [
        "1. Expand the Hotels Filters section if collapsed",
        "2. Focus the Location_Area input field",
        "3. Enter a very long free-text value (200+ characters) into Location_Area, including punctuation and unicode characters",
        "4. Move focus away from the input to trigger on_change",
        "5. Observe Results_Grid and Result_Count",
        "6. Observe Active_Filters_Summary and the displayed Location_Area label"
      ],
      "expected_result": "Entering a very long string into Location_Area succeeds (input accepted); results update dynamically and Result_Count updates; Active_Filters_Summary shows a Location_Area filter entry \u2014 the displayed label is visibly truncated in the summary with an ellipsis if the UI limits label width, and full text is available via hover/tooltip or detail on click (visible truncation behavior shown)",
      "priority": "low"
    },
    {
      "tc_id": "E-006",
      "wf_ref": "WF-018",
      "subcategory": "interaction_edge",
      "test_case": "Reset all filters then use browser Back to verify filters are not reapplied",
      "preconditions": [
        "Listing page is open"
      ],
      "steps": [
        "1. Apply multiple filters across sections (e.g., set Price_Range and a Star_Or_Review_Rating and one listing-specific filter)",
        "2. Observe Results_Grid and Result_Count change from baseline",
        "3. Click the sidebar 'Reset all filters' button",
        "4. Observe that all filters clear, Active_Filters_Summary becomes empty, and Result_Count shows the unfiltered total",
        "5. Immediately press the browser Back button once",
        "6. Observe the filters, Active_Filters_Summary, and Result_Count after navigation"
      ],
      "expected_result": "Clicking Reset all filters succeeds: all filters clear, Active_Filters_Summary is empty, and Result_Count shows the unfiltered total; pressing the browser Back button does not reapply the cleared filters (no filters reappear in sidebar or Active_Filters_Summary) \u2014 UI remains in the cleared state or navigates back without restoring the previously applied filters",
      "priority": "medium"
    }
  ],
