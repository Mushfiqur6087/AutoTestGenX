      "name": "Submit with File Upload submission type",
      "actor": "<role>",
      "conditional_branch": "Submission_Type == File_Upload",
      "terminal_action": "Submit",
      "on_success": "Assignment created; success message shown"
    }
  ],
  "total": 2
}


