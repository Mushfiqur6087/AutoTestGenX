{
  "module_name": "Cars Search & Listing",
  "components": {
    "Car_Search_Form": {
      "type": "form",
      "fields": {
        "Pick_Up_Location": {
          "type": "search"
        },
        "Drop_Off_Location": {
          "type": "search"
        },
        "Pick_Up_Date": {
          "type": "date"
        },
        "Pick_Up_Time": {
          "type": "unspecified"
        },
        "Drop_Off_Date": {
          "type": "date"
        },
        "Drop_Off_Time": {
          "type": "unspecified"
        },
        "Driver_Age": {
          "type": "number"
        }
      },
      "constraints": [
        "Drop_Off_Date >= Pick_Up_Date"
      ],
      "submit_actions": [
        {
          "element_name": "Search",
          "on_success": "redirects to Listing_Page"
        }
      ]
    },
    "Listing_Page": {
      "type": "page",
      "components": {
        "Sidebar_Filters": {
          "type": "panel",
          "on_change": "updates results dynamically",
          "fields": {
            "Car_Type": {
              "type": "multiselect",
              "options": [
                "Economy",
                "Compact",
                "SUV",
                "Luxury",
                "Van"
              ]
            },
            "Transmission": {
              "type": "multiselect",
              "options": [
                "Automatic",
                "Manual"
              ]
            },
            "Fuel_Policy": {
              "type": "multiselect"
            },
            "Rental_Company": {
              "type": "multiselect"
            },
            "Price_Range": {
              "type": "unspecified"
            }
          }
        },
        "Vehicles_List": {
          "type": "grouped_list",
          "grouped_by": "Car_Type",
          "item_fields": {
            "Vehicle_Image": {
              "type": "image"
            },
            "Make_and_Model": {
              "type": "text"
            },
            "Transmission_Type": {
              "type": "text",
              "options": [
                "Automatic",
                "Manual"
              ]
            },
            "Fuel_Policy": {
              "type": "text"
            },
            "Seating_Capacity": {
              "type": "number"
            },
            "Luggage_Capacity": {
              "type": "number"
            },
            "Features": {
              "type": "list",
              "items": [
                "AC",
                "GPS",
                "etc."
              ]
            },
            "Price_Per_Day": {
              "type": "currency"
            },
            "Total_Rental_Cost": {
              "type": "currency",
              "computed": "Price_Per_Day * rental_days"
            },
            "Book_Now": {
              "type": "button",
              "element_name": "Book Now",
              "on_success": "initiates booking flow"
            }
          },
          "groups": {
            "Economy": {
              "items": []
            },
            "Compact": {
              "items": []
            },
            "SUV": {
              "items": []
            },
            "Luxury": {
              "items": []
            },
            "Van": {
              "items": []
            }
          }
        }
      }
    }
  }
}
